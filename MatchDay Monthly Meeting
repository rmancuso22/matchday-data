/* =====================================================
   CSV PARSING
   ===================================================== */
function parseCSV(text) {
  const rows = [];
  let row = [], field = '', inQuotes = false;
  for (let i = 0; i < text.length; i++) {
    const c = text[i];
    if (inQuotes) {
      if (c === '"' && text[i+1] === '"') { field += '"'; i++; }
      else if (c === '"') inQuotes = false;
      else field += c;
    } else {
      if (c === '"') inQuotes = true;
      else if (c === ',') { row.push(field); field = ''; }
      else if (c === '\n') { row.push(field); rows.push(row); row = []; field = ''; }
      else if (c === '\r') {}
      else field += c;
    }
  }
  if (field.length > 0 || row.length > 0) { row.push(field); rows.push(row); }
  return rows;
}

function rowsToObjects(rows) {
  if (!rows.length) return [];
  const headers = rows[0].map(h => h.trim());
  return rows.slice(1)
    .filter(r => r.some(c => c && c.trim()))
    .map(r => {
      const obj = {};
      headers.forEach((h, i) => obj[h] = (r[i] || '').trim());
      return obj;
    });
}

function findCol(headers, keywords) {
  const lower = headers.map(h => (h || '').toLowerCase());
  for (const kw of keywords) {
    const idx = lower.findIndex(h => h.includes(kw.toLowerCase()));
    if (idx !== -1) return idx;
  }
  return -1;
}

/* =====================================================
   STATS COMPUTATION FROM REGISTRATION CSV
   ===================================================== */
function computeStats(records) {
  // Build first-ever-match map per user
  const firstMatch = {};
  for (const r of records) {
    const ts = new Date(r['Date Of Match Registration']);
    if (isNaN(ts)) continue;
    const uid = r['User ID'];
    if (!uid) continue;
    if (!firstMatch[uid] || ts < firstMatch[uid]) firstMatch[uid] = ts;
  }

  const byMonth = {};  // key: "2026-03" -> stats
  for (const r of records) {
    const ts = new Date(r['Date Of Match Registration']);
    if (isNaN(ts)) continue;
    if (r['Match Canceled'] === 'true') continue;

    const key = `${ts.getFullYear()}-${String(ts.getMonth()+1).padStart(2,'0')}`;
    if (!byMonth[key]) byMonth[key] = { cities: {}, allPlayers: new Set(), newPlayers: new Set(), allMatches: new Set(), regs: 0, memberRegs: 0, revenue: 0 };
    const M = byMonth[key];

    const city = r['City'] || 'Unknown';
    if (!M.cities[city]) M.cities[city] = { matches: new Set(), regs: 0, players: new Set(), newPlayers: new Set(), memberRegs: 0, revenue: 0 };
    const C = M.cities[city];

    const matchKey = `${r['Field']}|${r['Match Start']}`;
    C.matches.add(matchKey);
    M.allMatches.add(`${city}|${matchKey}`);
    C.regs++; M.regs++;
    const uid = r['User ID'];
    if (uid) {
      C.players.add(uid);
      M.allPlayers.add(uid);
      if (firstMatch[uid] && firstMatch[uid].getFullYear() === ts.getFullYear() && firstMatch[uid].getMonth() === ts.getMonth()) {
        C.newPlayers.add(uid);
        M.newPlayers.add(uid);
      }
    }
    if (r['Type Of Payment'] === 'MEMBER') { C.memberRegs++; M.memberRegs++; }
    const price = parseFloat(r['Match price paid']);
    if (!isNaN(price)) { C.revenue += price; M.revenue += price; }
  }

  // Collapse sets to counts
  for (const key of Object.keys(byMonth)) {
    const M = byMonth[key];
    M.matches = M.allMatches.size;
    M.players = M.allPlayers.size;
    M.newPlayersCount = M.newPlayers.size;
    for (const cname of Object.keys(M.cities)) {
      const C = M.cities[cname];
      C.matchesCount = C.matches.size;
      C.playersCount = C.players.size;
      C.newPlayersCount = C.newPlayers.size;
    }
  }

  // Cumulative
  const totalRegistrations = records.filter(r => r['Match Canceled'] !== 'true').length;
  const uniquePlayersEver = new Set(records.map(r => r['User ID']).filter(Boolean)).size;

  return { byMonth, totalRegistrations, uniquePlayersEver };
}

/* =====================================================
   RENDER
   ===================================================== */
function renderAll(stats, meetingMonth, prevMonth) {
  const M = stats.byMonth[meetingMonth];
  const P = stats.byMonth[prevMonth];

  if (!M) {
    document.getElementById('hero-sub').textContent = 'No data available for the selected month.';
    return;
  }

  // ----- Month tag -----
  const [year, monthNum] = meetingMonth.split('-').map(Number);
  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const monthDisplay = `${monthNames[monthNum-1].toUpperCase()} ${year}`;
  document.getElementById('month-tag').textContent = monthDisplay;

  // ----- Hero sub -----
  document.getElementById('hero-sub').textContent = `What happened across the network in ${monthNames[monthNum-1]} ${year}. Numbers pulled from the latest match registration export.`;

  // ----- Stats -----
  const statCards = [
    { label: 'Matches played', value: M.matches, prev: P ? P.matches : null, sub: `across ${Object.keys(M.cities).length} cities` },
    { label: 'Total registrations', value: M.regs, prev: P ? P.regs : null, sub: `${Math.round(M.regs / M.matches)} avg per match` },
    { label: 'Unique players', value: M.players, prev: P ? P.players : null, sub: 'played at least once' },
    { label: 'New players', value: M.newPlayersCount, prev: P ? P.newPlayersCount : null, sub: 'first-ever match' },
    { label: 'Member regs', value: M.memberRegs, prev: P ? P.memberRegs : null, sub: `${Math.round(100*M.memberRegs/M.regs)}% of all regs` },
  ];
  document.getElementById('stats-grid').innerHTML = statCards.map(s => {
    let change = '';
    if (s.prev !== null && s.prev > 0) {
      const pct = Math.round(((s.value - s.prev) / s.prev) * 100);
      const cls = pct > 0 ? 'up' : pct < 0 ? 'down' : 'flat';
      const arrow = pct > 0 ? '↑' : pct < 0 ? '↓' : '→';
      change = `<div class="stat-change ${cls}"><span class="arrow">${arrow}</span>${pct > 0 ? '+' : ''}${pct}% vs prev month</div>`;
    }
    return `
      <div class="stat">
        <div class="stat-label">${s.label}</div>
        <div class="stat-value">${s.value.toLocaleString()}</div>
        ${change}
        <div class="stat-sub">${s.sub}</div>
      </div>`;
  }).join('');

  // ----- City table -----
  const CITY_ORDER = ['Austin', 'Houston', 'San Antonio', 'Dallas / Fort Worth', 'Atlanta', 'St. Louis', 'Oklahoma City', 'El Paso'];
  const cityKeys = Object.keys(M.cities).sort((a,b) => {
    const ai = CITY_ORDER.indexOf(a); const bi = CITY_ORDER.indexOf(b);
    if (ai >= 0 && bi >= 0) return ai - bi;
    if (ai >= 0) return -1;
    if (bi >= 0) return 1;
    return a.localeCompare(b);
  });

  let tableHtml = `
    <div class="city-row header">
      <div>City</div>
      <div class="num">Matches</div>
      <div class="num hide-sm">Registrations</div>
      <div class="num">Unique Players</div>
      <div class="num hide-sm">New Players</div>
      <div class="num hide-sm">Member %</div>
    </div>`;
  cityKeys.forEach(c => {
    const C = M.cities[c];
    const prevC = P && P.cities[c];
    const memberPct = C.regs > 0 ? Math.round(100 * C.memberRegs / C.regs) : 0;
    const matchDelta = prevC ? ((C.matchesCount - prevC.matchesCount) / (prevC.matchesCount || 1) * 100).toFixed(0) : null;
    const regsDelta = prevC ? ((C.regs - prevC.regs) / (prevC.regs || 1) * 100).toFixed(0) : null;
    const playerDelta = prevC ? ((C.playersCount - prevC.playersCount) / (prevC.playersCount || 1) * 100).toFixed(0) : null;
    const newDelta = prevC ? ((C.newPlayersCount - prevC.newPlayersCount) / (prevC.newPlayersCount || 1) * 100).toFixed(0) : null;
    tableHtml += `
      <div class="city-row data">
        <div class="city-name"><div class="bar-mini"></div>${c}</div>
        <div class="num">${C.matchesCount}${matchDelta !== null ? `<span class="num-sub">${matchDelta > 0 ? '+' : ''}${matchDelta}%</span>` : ''}</div>
        <div class="num hide-sm">${C.regs.toLocaleString()}${regsDelta !== null ? `<span class="num-sub">${regsDelta > 0 ? '+' : ''}${regsDelta}%</span>` : ''}</div>
        <div class="num">${C.playersCount}${playerDelta !== null ? `<span class="num-sub">${playerDelta > 0 ? '+' : ''}${playerDelta}%</span>` : ''}</div>
        <div class="num hide-sm">${C.newPlayersCount}${newDelta !== null ? `<span class="num-sub">${newDelta > 0 ? '+' : ''}${newDelta}%</span>` : ''}</div>
        <div class="num hide-sm">${memberPct}%</div>
      </div>`;
  });
  const overallMemberPct = M.regs > 0 ? Math.round(100 * M.memberRegs / M.regs) : 0;
  tableHtml += `
    <div class="city-row total">
      <div class="city-name"><div class="bar-mini"></div>All Cities</div>
      <div class="num">${M.matches}</div>
      <div class="num hide-sm">${M.regs.toLocaleString()}</div>
      <div class="num">${M.players.toLocaleString()}</div>
      <div class="num hide-sm">${M.newPlayersCount}</div>
      <div class="num hide-sm">${overallMemberPct}%</div>
    </div>`;
  document.getElementById('city-table').innerHTML = tableHtml;
  document.getElementById('city-meta').textContent = `${cityKeys.length} active cities · ${monthDisplay}`;

  // ----- Callouts: auto-detect biggest mover, most at-risk, standout -----
  const callouts = [];
  if (P) {
    let biggestGain = null, biggestLoss = null;
    cityKeys.forEach(c => {
      const C = M.cities[c];
      const prevC = P.cities[c];
      if (!prevC || prevC.matchesCount === 0) return;
      const delta = (C.matchesCount - prevC.matchesCount) / prevC.matchesCount;
      if (!biggestGain || delta > biggestGain.delta) biggestGain = { city: c, delta, abs: C.matchesCount - prevC.matchesCount };
      if (!biggestLoss || delta < biggestLoss.delta) biggestLoss = { city: c, delta, abs: C.matchesCount - prevC.matchesCount };
    });
    if (biggestGain && biggestGain.delta > 0.1) {
      callouts.push({
        type: 'win', tag: '📈 Biggest mover',
        headline: `${biggestGain.city} grew ${Math.round(biggestGain.delta*100)}%`,
        body: `${biggestGain.abs > 0 ? '+' : ''}${biggestGain.abs} matches vs previous month. What is working there?`
      });
    }
    if (biggestLoss && biggestLoss.delta < -0.1) {
      callouts.push({
        type: 'watch', tag: '⚠ Needs attention',
        headline: `${biggestLoss.city} fell ${Math.round(biggestLoss.delta*100)}%`,
        body: `${biggestLoss.abs} matches vs previous month. Dig into the why during this manager's turn.`
      });
    }
  }
  // Cities with zero matches flag
  const quietCities = cityKeys.filter(c => M.cities[c].matchesCount <= 5);
  if (quietCities.length > 0) {
    callouts.push({
      type: 'watch', tag: '🚨 Cold start',
      headline: `${quietCities.join(', ')} ran ≤5 matches`,
      body: `These markets need focused operational support. Check in with these managers individually.`
    });
  }
  document.getElementById('callouts').innerHTML = callouts.map(c => `
    <div class="callout ${c.type}">
      <div class="tag">${c.tag}</div>
      <div class="headline">${c.headline}</div>
      <div class="body">${c.body}</div>
    </div>`).join('');

  // ----- Deep dive theme -----
  const theme = DEEP_DIVE_THEMES[monthNum] || DEEP_DIVE_THEMES[1];
  document.getElementById('deep-kicker').textContent = `03 · Deep dive · ${monthNames[monthNum-1]}`;
  document.getElementById('deep-title').innerHTML = `${theme.title.split(' ').slice(0,-1).join(' ')} <span class="accent">${theme.accent}</span>`;
  document.getElementById('deep-body').textContent = theme.body;
  document.getElementById('deep-questions').innerHTML = theme.questions.map((q, i) =>
    `<div class="q"><div class="q-num">Q${i+1}</div><div>${q}</div></div>`
  ).join('');
}

/* =====================================================
   CHECKIN RENDERING
   ===================================================== */
function renderCheckins(rows, meetingMonth) {
  const MANAGERS = [
    { name: "Yarra",     city: "Houston",      cityKeywords: ["houston"] },
    { name: "Abraham",   city: "San Antonio",  cityKeywords: ["san antonio"] },
    { name: "Gabe",      city: "North Austin", cityKeywords: ["austin"] },
    { name: "Willfried", city: "St Louis",     cityKeywords: ["st louis", "st. louis"] },
    { name: "Anton",     city: "El Paso",      cityKeywords: ["el paso"] },
    { name: "Chris",     city: "DFW",          cityKeywords: ["dfw", "dallas", "fort worth"] },
    { name: "Rodrigo",   city: "OKC",          cityKeywords: ["okc", "oklahoma"] },
  ];

  if (!rows || rows.length < 2) {
    document.getElementById('checkin-grid').innerHTML = `<div class="empty-state"><h3>No check-ins loaded yet</h3><p>Once managers submit their monthly check-ins, they'll appear here.</p></div>`;
    return;
  }
  const headers = rows[0];
  const data = rows.slice(1).filter(r => r.some(c => c && c.trim()));

  const idx = {
    timestamp: findCol(headers, ['timestamp']),
    city: findCol(headers, ['city']),
    rating: findCol(headers, ['rating', 'overall']),
    win: findCol(headers, ['biggest win']),
    challenge: findCol(headers, ['biggest challenge']),
    focus: findCol(headers, ['primary focus', 'focus for next']),
    fieldProgress: findCol(headers, ['progress update', 'field relationships']),
    matchMgr: findCol(headers, ['match manager']),
    marketingResults: findCol(headers, ['results from', 'marketing results']),
  };

  // Latest per city
  const latestByCity = {};
  data.forEach(r => {
    const city = idx.city >= 0 ? r[idx.city] : 'Unknown';
    const ts = idx.timestamp >= 0 ? new Date(r[idx.timestamp]) : new Date(0);
    if (!latestByCity[city] || ts > latestByCity[city]._ts) latestByCity[city] = { _ts: ts, row: r };
  });

  const [year, monthNum] = meetingMonth.split('-').map(Number);
  const monthStart = new Date(year, monthNum-1, 1);
  const monthEnd = new Date(year, monthNum, 1);
  let submittedCount = 0;

  const html = MANAGERS.map(m => {
    const key = Object.keys(latestByCity).find(c => {
      const cl = c.toLowerCase();
      return m.cityKeywords.some(kw => cl.includes(kw));
    });
    const entry = key ? latestByCity[key] : null;
    const submittedThisMonth = entry && entry._ts >= monthStart && entry._ts < new Date(monthEnd.getTime() + 14*24*3600*1000);
    if (submittedThisMonth) submittedCount++;

    if (!entry || !submittedThisMonth) {
      return `
        <div class="checkin-card pending">
          <div class="head">
            <div>
              <div class="name">${m.name}</div>
              <div class="city-tag">${m.city}</div>
            </div>
            <div class="pill pending">Awaiting</div>
          </div>
          <div class="val" style="color:var(--ink-4);font-style:italic;font-size:13px;">No check-in submitted for this month yet.</div>
        </div>`;
    }

    const r = entry.row;
    const get = i => i >= 0 ? (r[i] || '').trim() : '';
    const rating = parseFloat(get(idx.rating)) || 0;
    const tsStr = entry._ts.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toUpperCase();

    return `
      <div class="checkin-card">
        <div class="head">
          <div>
            <div class="name">${m.name}</div>
            <div class="city-tag">${m.city}</div>
          </div>
          <div class="pill submitted">Submitted</div>
        </div>
        ${rating ? `
          <div class="rating-bar-label">Overall rating</div>
          <div class="rating-bar">
            <div class="rating-num">${rating.toFixed(1)}</div>
            <div class="rating-bar-track"><div class="rating-bar-fill" style="width:${rating/5*100}%"></div></div>
          </div>` : ''}
        ${get(idx.win) ? `<div class="checkin-section"><div class="label">🏆 Biggest win</div><div class="val">${esc(get(idx.win))}</div></div>` : ''}
        ${get(idx.challenge) ? `<div class="checkin-section"><div class="label">⚠ Biggest challenge</div><div class="val">${esc(get(idx.challenge))}</div></div>` : ''}
        ${get(idx.focus) ? `<div class="checkin-section"><div class="label">🎯 Next month focus</div><div class="val">${esc(get(idx.focus))}</div></div>` : ''}
        <div class="submitted-line">Submitted ${tsStr}</div>
      </div>`;
  }).join('');

  document.getElementById('checkin-grid').innerHTML = html;
  document.getElementById('checkin-meta').textContent = `${submittedCount}/${MANAGERS.length} submitted`;
}

function esc(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

/* =====================================================
   LOAD FLOW
   ===================================================== */
let latestStats = null;

async function loadDefaultData() {
  try {
    const res = await fetch(DEFAULT_DATA_CSV);
    if (!res.ok) throw new Error('No default CSV at ' + DEFAULT_DATA_CSV);
    const text = await res.text();
    processCSV(text);
  } catch (e) {
    document.getElementById('hero-sub').innerHTML = `No data file loaded. Click <strong>↑ Load new CSV</strong> above to load your monthly export.`;
    document.getElementById('stats-grid').innerHTML = '';
  }
}

function processCSV(text) {
  const rows = parseCSV(text);
  const records = rowsToObjects(rows);
  const stats = computeStats(records);
  latestStats = stats;

  // Find latest complete month (the month with the most recent data)
  const months = Object.keys(stats.byMonth).sort();
  const meetingMonth = months[months.length - 1];
  const prevMonth = months[months.length - 2];
  renderAll(stats, meetingMonth, prevMonth);
}

function handleFileUpload(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => processCSV(e.target.result);
  reader.readAsText(file);
}

loadDefaultData();
