<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MatchDay Monthly All-Hands</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Titillium+Web:wght@300;400;600;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    /* MatchDay brand palette (pulled from site) */
    --md-forest: #0D1F17;      /* deepest forest — backgrounds */
    --md-forest-2: #002a1f;    /* near-black forest */
    --md-forest-3: #003326;    /* card bg on dark */
    --md-green: #0B4D3B;       /* mid green — primary text/button */
    --md-green-2: #0f5f49;     /* slightly lighter */
    --md-mint: #2CDB87;        /* signature mint accent */
    --md-mint-soft: #C8E8D4;   /* light mint tint */
    --md-sage: #9BBFAA;        /* muted sage */
    --md-gold: #D9BC63;        /* gold highlight */
    --md-cream: #F4EEE1;       /* warm paper bg */
    --md-cream-2: #FAF6EC;     /* lighter cream */

    /* Utility */
    --ink: #0D1F17;
    --ink-2: #2a3d33;
    --ink-3: #5b6e64;
    --ink-4: #8a9a91;
    --line: rgba(13, 31, 23, 0.1);
    --line-strong: rgba(13, 31, 23, 0.18);
    --bg: var(--md-cream);
    --bg-card: #ffffff;
    --red: #B53228;
    --amber: #A87729;
    --amber-bg: #FAF1DC;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: var(--bg); color: var(--ink); font-family: 'Titillium Web', sans-serif; -webkit-font-smoothing: antialiased; }

  /* ===== Banner ===== */
  .banner {
    background: var(--md-forest);
    color: var(--md-mint);
    padding: 10px 32px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
  }

  /* ===== Header ===== */
  header {
    padding: 28px 32px 24px;
    border-bottom: 1px solid rgba(44, 219, 135, 0.15);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    background: var(--md-forest);
  }
  .brand {
    display: flex; align-items: center; gap: 20px;
  }
  .logo-img {
    height: 38px; width: auto;
  }
  .brand-text {
  }
  .brand-text .top-label {
    font-size: 10px; font-weight: 700; letter-spacing: 0.2em; color: var(--md-mint);
    text-transform: uppercase;
  }
  .brand-text .title {
    font-size: 20px; font-weight: 700; letter-spacing: -0.01em; color: var(--md-cream);
    margin-top: 2px;
  }
  .meeting-tag {
    display: flex; flex-direction: column; align-items: flex-end; gap: 8px;
  }
  .month-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--md-mint);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .file-loader {
    display: flex; gap: 8px; align-items: center;
  }
  .file-btn {
    background: transparent;
    border: 1px dashed rgba(44, 219, 135, 0.3);
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    cursor: pointer;
    color: var(--md-sage);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: all 0.15s ease;
  }
  .file-btn:hover { background: rgba(44, 219, 135, 0.1); color: var(--md-mint); border-color: var(--md-mint); }
  input[type=file] { display: none; }

  /* ===== Hero ===== */
  .hero {
    padding: 56px 32px 56px;
    background: var(--md-forest);
    color: var(--md-cream);
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, var(--md-mint) 0%, transparent 70%);
    opacity: 0.08;
    border-radius: 50%;
  }
  .hero h1 {
    font-size: 68px;
    font-weight: 900;
    letter-spacing: -0.035em;
    line-height: 0.95;
    margin-bottom: 14px;
    color: var(--md-cream);
    position: relative;
  }
  .hero h1 .accent { color: var(--md-mint); font-style: italic; }
  .hero-sub {
    font-size: 17px;
    color: var(--md-sage);
    max-width: 700px;
    margin-bottom: 40px;
    line-height: 1.5;
    position: relative;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 14px;
    position: relative;
  }
  .stat {
    background: var(--md-forest-3);
    border: 1px solid rgba(44, 219, 135, 0.12);
    border-radius: 14px;
    padding: 22px 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }
  .stat:hover {
    border-color: rgba(44, 219, 135, 0.4);
  }
  .stat-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--md-sage);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 14px;
  }
  .stat-value {
    font-size: 44px;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--md-cream);
    line-height: 1;
  }
  .stat-change {
    margin-top: 10px;
    font-size: 12px;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .stat-change.up { color: var(--md-mint); }
  .stat-change.down { color: #ff7a6b; }
  .stat-change.flat { color: var(--md-sage); }
  .stat-change .arrow { font-size: 14px; }
  .stat-sub {
    font-size: 11px;
    color: var(--md-sage);
    margin-top: 4px;
    font-family: 'JetBrains Mono', monospace;
  }

  /* ===== Section ===== */
  section { padding: 56px 32px; border-bottom: 1px solid var(--line); background: var(--bg-card); }
  section:nth-of-type(even) { background: var(--md-cream-2); }
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 16px;
    flex-wrap: wrap;
  }
  .section-head h2 {
    font-size: 40px;
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--md-forest);
  }
  .section-head .kicker {
    font-size: 11px;
    font-weight: 700;
    color: var(--md-mint);
    background: var(--md-forest);
    padding: 4px 10px;
    border-radius: 20px;
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 12px;
  }
  .section-head .meta {
    font-size: 12px;
    color: var(--ink-3);
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ===== Agenda ===== */
  .agenda {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-card);
  }
  .agenda-step {
    padding: 22px 20px;
    border-right: 1px solid var(--line);
    position: relative;
    transition: background 0.15s ease;
  }
  .agenda-step:hover { background: var(--md-cream); }
  .agenda-step:last-child { border-right: none; }
  .agenda-step .time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--md-green);
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: 0.08em;
  }
  .agenda-step .title {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
    color: var(--md-forest);
  }
  .agenda-step .desc {
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.5;
  }

  /* ===== City table ===== */
  .city-table {
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-card);
  }
  .city-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr;
    align-items: center;
    padding: 16px 22px;
    border-bottom: 1px solid var(--line);
    transition: background 0.15s ease;
  }
  .city-row:last-child { border-bottom: none; }
  .city-row.header {
    background: var(--md-cream);
    font-size: 10px;
    font-weight: 700;
    color: var(--md-green);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .city-row.data:hover { background: var(--md-mint-soft); }
  .city-row .city-name {
    font-weight: 700;
    font-size: 15px;
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--md-forest);
  }
  .city-row .city-name .bar-mini {
    width: 4px;
    height: 26px;
    background: var(--md-mint);
    border-radius: 2px;
  }
  .city-row .num {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    font-size: 14px;
    color: var(--md-forest);
  }
  .city-row .num-sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--ink-4);
    display: block;
    margin-top: 2px;
    font-weight: 500;
  }
  .city-row.total {
    background: var(--md-forest);
    color: var(--md-cream);
    font-weight: 800;
  }
  .city-row.total .city-name, .city-row.total .num { color: var(--md-cream); }
  .city-row.total .bar-mini { background: var(--md-gold); }

  /* Flag callouts */
  .callouts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 14px;
    margin-top: 28px;
  }
  .callout {
    padding: 20px 22px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--bg-card);
  }
  .callout.watch { border-left: 4px solid var(--md-gold); background: var(--amber-bg); }
  .callout.win { border-left: 4px solid var(--md-mint); background: var(--md-mint-soft); }
  .callout .tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .callout.watch .tag { color: var(--amber); }
  .callout.win .tag { color: var(--md-green); }
  .callout .headline { font-size: 16px; font-weight: 700; margin-bottom: 6px; color: var(--md-forest); }
  .callout .body { font-size: 13px; color: var(--ink-2); line-height: 1.5; }

  /* ===== Check-ins section ===== */
  .checkin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 14px;
    align-items: start;
  }
  .checkin-card {
    background: white;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 22px;
    position: relative;
  }
  .checkin-card.pending {
    border-style: dashed;
    border-color: var(--line-strong);
    opacity: 0.6;
  }
  .checkin-card .head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: 14px;
    margin-bottom: 14px;
    border-bottom: 1px solid var(--line);
  }
  .checkin-card .name {
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  .checkin-card .city-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 2px;
  }
  .pill {
    font-size: 10px;
    font-weight: 700;
    padding: 4px 9px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  .pill.submitted { background: var(--md-green-bg); color: var(--md-green); }
  .pill.pending { background: #f3f4f6; color: var(--ink-3); }
  .rating-bar {
    display: flex; align-items: baseline; gap: 10px;
    margin: 10px 0 14px;
  }
  .rating-num { font-size: 36px; font-weight: 900; color: var(--md-green); letter-spacing: -0.03em; line-height: 1; }
  .rating-bar-track { flex: 1; height: 5px; background: #f3f4f6; border-radius: 3px; overflow: hidden; }
  .rating-bar-fill { height: 100%; background: linear-gradient(90deg, var(--md-green-light), var(--md-green)); border-radius: 3px; }
  .rating-bar-label { font-size: 9px; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.08em; font-family: 'JetBrains Mono', monospace; }

  .checkin-section { margin-top: 12px; }
  .checkin-section .label {
    font-size: 9px;
    font-weight: 700;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 4px;
    display: flex; align-items: center; gap: 6px;
  }
  .checkin-section .val {
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink);
  }
  .checkin-card .submitted-line {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--ink-4);
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px dashed var(--line);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ===== Deep dive / footer ===== */
  .deep-dive {
    background: var(--md-forest);
    color: var(--md-cream);
    padding: 56px 36px;
    border-radius: 18px;
    margin: 56px 32px;
    border: none;
    position: relative;
    overflow: hidden;
  }
  .deep-dive::before {
    content: '';
    position: absolute;
    bottom: -100px; left: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, var(--md-mint) 0%, transparent 70%);
    opacity: 0.06;
    border-radius: 50%;
  }
  .deep-dive h3 {
    font-size: 52px;
    font-weight: 900;
    letter-spacing: -0.035em;
    margin-bottom: 16px;
    line-height: 0.95;
    position: relative;
  }
  .deep-dive h3 .accent { color: var(--md-mint); font-style: italic; }
  .deep-dive .theme-kicker {
    font-size: 11px;
    color: var(--md-forest);
    background: var(--md-mint);
    padding: 4px 10px;
    border-radius: 20px;
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    margin-bottom: 14px;
    position: relative;
  }
  .deep-dive .body {
    font-size: 16px;
    color: var(--md-sage);
    line-height: 1.6;
    max-width: 780px;
    margin-bottom: 24px;
    position: relative;
  }
  .deep-dive .questions {
    display: grid;
    gap: 10px;
    max-width: 780px;
    position: relative;
  }
  .deep-dive .q {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 16px 20px;
    background: rgba(44, 219, 135, 0.06);
    border-radius: 10px;
    border: 1px solid rgba(44, 219, 135, 0.14);
    color: var(--md-cream);
    font-size: 14px;
    line-height: 1.5;
  }
  .deep-dive .q-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--md-mint);
    font-weight: 700;
    flex-shrink: 0;
    letter-spacing: 0.06em;
    padding-top: 2px;
  }

  .empty-state {
    padding: 60px 32px;
    text-align: center;
    color: var(--ink-3);
  }
  .empty-state h3 { font-size: 20px; color: var(--ink); margin-bottom: 8px; }

  footer {
    padding: 32px;
    background: var(--md-forest-2);
    color: var(--md-sage);
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 14px;
  }
  footer .brand-ft { color: var(--md-mint); font-weight: 700; }

  @media (max-width: 900px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
    .agenda { grid-template-columns: 1fr 1fr; }
    .agenda-step { border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    .hero h1 { font-size: 44px; }
    .section-head h2 { font-size: 28px; }
    .deep-dive h3 { font-size: 32px; }
    .city-row { grid-template-columns: 1.5fr 1fr 1fr; font-size: 12px; }
    .city-row .hide-sm { display: none; }
    section { padding: 32px 20px; }
    .hero { padding: 32px 20px; }
    header { padding: 20px; }
  }
</style>
</head>
<body>

<header>
  <div class="brand">
    <div class="brand-text">
      <div class="top-label">Operations</div>
      <div class="title">MatchDay Monthly All-Hands</div>
    </div>
  </div>
  <div class="meeting-tag">
    <div class="month-tag" id="month-tag">— LOADING —</div>
    <div class="file-loader">
      <label class="file-btn" for="csv-upload">↑ Load new CSV</label>
      <input type="file" id="csv-upload" accept=".csv" onchange="handleFileUpload(event)">
    </div>
  </div>
</header>

<!-- ===== HERO ===== -->
<div class="hero">
  <h1>The State of <span class="accent">Play.</span></h1>
  <p class="hero-sub" id="hero-sub">Loading the latest numbers from across all MatchDay cities…</p>

  <div class="stats" id="stats-grid"></div>
</div>

<!-- ===== AGENDA ===== -->
<section>
  <div class="section-head">
    <div>
      <div class="kicker">01 · Running order</div>
      <h2>Today's Agenda</h2>
    </div>
    <div class="meta">45 min · 7 city managers</div>
  </div>

  <div class="agenda">
    <div class="agenda-step">
      <div class="time">0:00 — 0:03</div>
      <div class="title">Open</div>
      <div class="desc">Context + call-out of the month's biggest team win.</div>
    </div>
    <div class="agenda-step">
      <div class="time">0:03 — 0:10</div>
      <div class="title">Metrics</div>
      <div class="desc">Cross-city numbers pulse. Right on this page.</div>
    </div>
    <div class="agenda-step">
      <div class="time">0:10 — 0:25</div>
      <div class="title">Round Robin</div>
      <div class="desc">2 min each — win, challenge, focus. From your check-in.</div>
    </div>
    <div class="agenda-step">
      <div class="time">0:25 — 0:37</div>
      <div class="title">Deep Dive</div>
      <div class="desc">Rotating theme. Peer teaching.</div>
    </div>
    <div class="agenda-step">
      <div class="time">0:37 — 0:43</div>
      <div class="title">Open Floor</div>
      <div class="desc">"Anyone else hitting the same problem?"</div>
    </div>
    <div class="agenda-step">
      <div class="time">0:43 — 0:45</div>
      <div class="title">Close</div>
      <div class="desc">Action items. Next call date. Thanks.</div>
    </div>
  </div>
</section>

<!-- ===== CITY TABLE ===== -->
<section>
  <div class="section-head">
    <div>
      <div class="kicker">02 · City-by-city</div>
      <h2>The Network</h2>
    </div>
    <div class="meta" id="city-meta">— calculating —</div>
  </div>

  <div class="city-table" id="city-table"></div>

  <div class="callouts" id="callouts"></div>
</section>

<!-- ===== DEEP DIVE ===== -->
<div class="deep-dive">
  <div class="theme-kicker" id="deep-kicker">03 · Deep dive · This month</div>
  <h3 id="deep-title">Theme <span class="accent">TBD</span></h3>
  <p class="body" id="deep-body">
    This month's rotating theme will surface here. Pick 1-2 managers to present for 5 min on what's working in their city.
  </p>
  <div class="questions" id="deep-questions"></div>
</div>

<footer>
  <div class="brand-ft">MatchDay · Pickup Soccer. Organized. Filmed. Competitive.</div>
  <div>Internal ops page · Not for distribution</div>
</footer>

<script>
/* =====================================================
   CONFIG
   ===================================================== */
const CHECKIN_CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vQmzasZGvZavVJan2QFpMxWuhc7HNzWIxRKcx1VsQS7jUZej13C9ODkhN1bw1NFOSUa2fgHKYfySrIE/pub?output=csv';

// Default CSV path (committed to the repo) — falls back to embedded if missing
const DEFAULT_DATA_CSV = 'user_analysis.csv';

// Rotating deep-dive themes by month (1-12)
const DEEP_DIVE_THEMES = {
  1:  { title: 'Fields & Partnerships', accent: 'Fields.', body: "Who is closing new field deals, how are they approaching it, and where are current partnerships stuck? Field supply is the foundation — without it, we have nothing to offer players.", questions: ["Who has talked to a new field this month?", "What is the objection we keep hitting?", "Which existing field needs our attention most?"] },
